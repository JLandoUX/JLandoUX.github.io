---
import { person } from '../data/content';

const [firstName, lastName] = person.name.split(' ');
---

<section class="relative overflow-hidden px-8 py-20">
  <!-- Glow blobs -->
  <div class="absolute -top-20 -left-20 w-96 h-96 rounded-full"
       style="background: radial-gradient(circle, rgba(124,111,255,0.12) 0%, transparent 70%); pointer-events:none;"></div>
  <div class="absolute bottom-0 -right-10 w-72 h-72 rounded-full"
       style="background: radial-gradient(circle, rgba(79,209,197,0.08) 0%, transparent 70%); pointer-events:none;"></div>

  <div class="max-w-4xl mx-auto relative">
    <!-- Eyebrow -->
    <p class="flex items-center gap-3 text-accent-teal text-xs tracking-widest uppercase mb-5">
      <span class="inline-block w-6 h-px bg-accent-teal"></span>
      {person.availability}
    </p>

    <!-- Name -->
    <h1 class="font-display font-extrabold leading-none tracking-tight mb-2"
        style="font-size: clamp(2.8rem, 7vw, 5rem);">
      {firstName}<br />
      <span class="glow-text">{lastName}</span>
    </h1>

    <p class="font-display text-text-muted text-lg mb-8">{person.role}</p>

    <p class="text-sm leading-relaxed text-text-primary/60 max-w-lg mb-10">{person.tagline}</p>

    <div class="flex gap-4 flex-wrap">
      <a href="#work"
         class="px-7 py-3 bg-accent-purple text-bg-primary text-xs tracking-widest uppercase font-mono transition hover:opacity-80 hover:-translate-y-px">
        View my work
      </a>
      <a href="#contact"
         class="px-7 py-3 border border-glow text-text-muted text-xs tracking-widest uppercase font-mono transition hover:border-accent-teal hover:text-accent-teal">
        Get in touch
      </a>
    </div>
  </div>
</section>
