---
import { projects } from '../data/content';
---

<section id="work" class="px-8 py-16 border-t border-glow">
  <div class="max-w-4xl mx-auto">
    <p class="text-xs tracking-widest uppercase text-accent-purple mb-2">Selected Work</p>
    <h2 class="font-display font-bold text-3xl tracking-tight mb-10">Projects</h2>

    <div class="space-y-5">
      {projects.map((project) => (
        <a href={project.url}
           class="group relative flex justify-between items-start gap-6 p-7 bg-bg-surface border border-glow overflow-hidden transition hover:border-accent-purple/35 hover:bg-bg-surface2 block no-underline">

          <!-- Bottom gradient line on hover -->
          <span class="absolute bottom-0 left-0 w-full h-px gradient-line scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-300"></span>

          <div>
            <p class="text-xs tracking-widest uppercase text-accent-teal mb-1">{project.type}</p>
            <h3 class="font-display font-bold text-lg text-text-primary mb-2">{project.title}</h3>
            <p class="text-xs text-text-muted leading-relaxed max-w-lg">{project.description}</p>
            <div class="flex flex-wrap gap-1.5 mt-4">
              {project.tags.map((tag) => (
                <span class="text-xs px-2 py-0.5 border border-glow text-text-muted">{tag}</span>
              ))}
            </div>
          </div>

          <span class="text-xl text-white/10 group-hover:text-accent-purple group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all shrink-0">↗</span>
        </a>
      ))}
    </div>
  </div>
</section>
